# Local-only body files
gielinor/CLAUDE.local.md

# MCP server config (contains credentials)
.mcp.json
**/.mcp.json

# Claude Code user-local settings
.claude/settings.local.json
**/.claude/settings.local.json

# Python bytecode (hooks generate __pycache__/)
__pycache__/
*.pyc
*.pyo

# Switchboard live-mode runtime state (D-009, D-017, D-018, D-020; promoted S052)
switchboard/state.ndjson
switchboard/state-actors.json
switchboard/state-dwarves.json
switchboard/state-gnomes.json
switchboard/state-penguins.json
switchboard/state-instances.json
switchboard/state-switchboard.json
switchboard/state-names.json
switchboard/state-*.json.tmp.*
switchboard/state-comms-*.md
switchboard/chat.ndjson
switchboard/ritual-events.ndjson
switchboard/ritual-events.ndjson.tmp.*

# Transient cockpit diagnostic logs (debug-only writers removed; files regenerable)
switchboard/*-diag.log

# Embedded-terminal server (S058) — venv + throwaway smoke test
switchboard/.venv/
switchboard/_smoketest.py

# Cockpit (S064/S066) — venv + persistent WebView2 profile (localStorage lives here)
cockpit/.venv/
cockpit/.webview/
# Cockpit per-machine local config (on_top, bind host) — never shared; a committed
# {"host":"0.0.0.0"} would ship a wide bind as the default.
cockpit/config.json
# Cockpit icon artifacts: runtime diag log (rewritten each launch) + regenerable
# preview (both produced by make-icon.py / app.py; icon.ico is the committed asset).
cockpit/icon-apply.log
cockpit/icon-preview.png

# Intent narration sidecars (D-010) — transient agent self-narration
.claude/intent/*.txt
# Mode markers (communication-protocol.md) + archived intent/mode sidecars —
# transient per-session runtime, like state.ndjson (audit #8: were git-status
# clobber-fuel; the already-tracked .mode need a one-time `git rm --cached`).
.claude/intent/*.mode
.claude/intent/archive/

# Global narration sidecar (D-014) — system-voice broader-scope commentary
.claude/narration.txt

# Active-mode marker (D-011) — visualizer-only sidecar
.claude/active-mode.txt

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/
.idea/
*.swp
*~

# Obsidian vault config (per-brain vaults, S099) — local-only navigation lens, not brain content
.obsidian/
**/.obsidian/

# Secrets
.env
.env.*
*.pem
*.key

# read_comms.py audio outputs (regenerable)
tools/out/

# comms_append.py lockfiles (runtime, per-vault)
comms/active.md.lock
*/comms/active.md.lock
